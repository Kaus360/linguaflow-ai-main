# Hugging Face Inference API Key
# Used for Stage 2 Contextual Language Correction (FLAN-T5-large inference)
HF_API_KEY=your_huggingface_api_key_here

# Note:
# - Google ASR uses the public speech_recognition quota by default.
# - LanguageTool uses the free LanguageToolPublicAPI endpoint.
# - Edge TTS uses the free edge_tts proxy.
